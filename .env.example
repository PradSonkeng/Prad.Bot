# ─── MongoDB ───────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/whatsapp_bot

# ─── Bot ───────────────────────────────────────────────
BOT_NAME=Prad$Bot
BOT_VERSION=2.0.0
BOT_PREFIX=||
OWNER_NUMBER=22901234567   # Votre numéro SANS le +

# ─── Performances ──────────────────────────────────────
RATE_LIMIT_MAX=10          # Max commandes/minute par user
RATE_LIMIT_WINDOW=60000    # Fenêtre en ms

# ─── Oracle Cloud (optionnel) ──────────────────────────
#PORT=3000